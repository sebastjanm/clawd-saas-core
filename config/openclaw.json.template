{
  "agents": {
    "defaults": {
      "maxConcurrent": 3,
      "model": {
        "primary": "{{DEFAULT_MODEL}}"
      }
    }
  },
  "env": {
    "{{PROVIDER_ENV_KEY}}": "{{LLM_API_KEY}}"
  },
  "cron": {
    "enabled": true
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "{{GATEWAY_TOKEN}}"
    },
    "mode": "local"
  },
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "{{WEBHOOK_TOKEN}}",
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": [
      "hook:",
      "pipeline:"
    ]
  },
  "models": {
    "providers": {
      "{{PROVIDER}}": {
        "apiKey": "${{{PROVIDER_ENV_KEY}}}"
      }
    }
  }
}