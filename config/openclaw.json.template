{
  "agents": {
    "defaults": {
      "maxConcurrent": 3,
      "model": {
        "primary": "{{DEFAULT_MODEL}}"
      }
    }
  },
  "auth": {
    "profiles": {
      "{{PROVIDER}}:default": {
        "provider": "{{PROVIDER}}",
        "mode": "api_key"
      }
    }
  },
  "env": {
    "{{PROVIDER_ENV_KEY}}": "{{LLM_API_KEY}}"
  },
  "cron": {
    "enabled": true
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "{{GATEWAY_TOKEN}}"
    }
  },
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "{{WEBHOOK_TOKEN}}",
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": ["pipeline:"]
  }
}
